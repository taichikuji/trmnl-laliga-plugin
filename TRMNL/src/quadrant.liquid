<div class="layout layout--col layout--center gap text--center px--2">
  <span class="title title--large lg:title--xlarge" data-pixel-perfect="true">{{ t_title }}</span>

  <span class="value value--xxlarge lg:value--xxxlarge text--black" data-fit-value="true">{{ t_blocked_text }}</span>
</div>

{% render 'title_bar', svg_logo: svg_logo, title: t_status_bar, update_time: t_updated_text %}
