{%- assign lang_value = trmnl.plugin_settings.custom_fields_values.language | default: language | default: 'spanish' -%}
{%- assign lang = lang_value | downcase -%}

{%- assign is_blocked = false -%}
{%- assign dns_status = Status | append: '' -%}
{%- assign answer_count = Answer | size -%}
{%- if dns_status == '0' and answer_count > 25 -%}
  {%- assign is_blocked = true -%}
{%- endif -%}
{%- assign t_status_bar = 'hayahora.futbol' -%}

{%- if lang == 'english' -%}
  {%- assign t_title = 'Is there football now?' -%}
  {%- assign t_blocked_yes = 'YES' -%}
  {%- assign t_blocked_no = 'NO' -%}
  {%- assign t_desc_yes = '...and therefore, hundreds of legitimate websites are inaccessible.' -%}
  {%- assign t_desc_no = '...but when there is, hundreds of websites are inaccessible.' -%}
  {%- assign t_updated_label = 'Updated:' -%}
{%- else -%}
  {%- assign t_title = '¿Hay ahora fútbol?' -%}
  {%- assign t_blocked_yes = 'SÍ' -%}
  {%- assign t_blocked_no = 'NO' -%}
  {%- assign t_desc_yes = '...y por tanto, cientos de webs legítimas están inaccesibles.' -%}
  {%- assign t_desc_no = '...pero, cuando lo hay, cientos de webs están inaccesibles.' -%}
  {%- assign t_updated_label = 'Actualizado:' -%}
{%- endif -%}

{%- assign _ts = trmnl.system.timestamp_utc | default: 'now' -%}
{%- assign t_updated_val = _ts | date: "%s" | plus: trmnl.user.utc_offset | date: "%H:%M" -%}

{%- if is_blocked -%}
  {%- assign t_blocked_text = t_blocked_yes -%}
  {%- assign t_desc_long = t_desc_yes_long -%}
  {%- assign t_desc = t_desc_yes -%}
{%- else -%}
  {%- assign t_blocked_text = t_blocked_no -%}
  {%- assign t_desc_long = t_desc_no_long -%}
  {%- assign t_desc = t_desc_no -%}
{%- endif -%}


{%- assign t_updated_text = t_updated_label | append: ' ' | append: t_updated_val -%}

{% template title_bar %}
  <div class="title_bar">
    <img
      class="image-stroke image-stroke--large"
      src="data:image/svg+xml;base64,{{ svg_logo | base64_encode }}"
      width="28"
      height="28"
      alt="Logo" />
    <span class="title">{{ title }}</span>
    <span class="instance">
      {{ update_time }}
    </span>
  </div>
{% endtemplate %}